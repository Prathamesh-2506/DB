SELECT 
    CASE 
        WHEN Marks >= 40 THEN 'Pass'
        ELSE 'Fail'
    END AS Result,
    COUNT(*) AS Total_Students
FROM Student
GROUP BY 
    CASE 
        WHEN Marks >= 40 THEN 'Pass'
        ELSE 'Fail'
    END;
