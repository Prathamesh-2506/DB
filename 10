CREATE TABLE Employee (
    EmpID NUMBER PRIMARY KEY,
    EmpName VARCHAR2(50),
    Salary NUMBER
);


CREATE TABLE Employee_Audit (
    AuditID NUMBER GENERATED BY DEFAULT AS IDENTITY,
    EmpID NUMBER,
    OldSalary NUMBER,
    NewSalary NUMBER,
    UpdatedOn DATE
);


