CREATE OR REPLACE TRIGGER trg_salary_update
BEFORE UPDATE OF Salary
ON Employee
FOR EACH ROW
BEGIN
    INSERT INTO Employee_Audit
    (EmpID, OldSalary, NewSalary, UpdatedOn)
    VALUES
    (:OLD.EmpID, :OLD.Salary, :NEW.Salary, SYSDATE);
END;
/


